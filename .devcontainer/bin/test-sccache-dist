#! /usr/bin/env bash

# Ensure we're in the repo root
cd "$( cd "$( dirname "$(realpath -m "${BASH_SOURCE[0]}")" )" && pwd )/../.."
cd "${SCCACHE_REPO:-$(pwd)}"

readarray -t old_containers < <(docker ps -aq --filter "name=sccache_dist_*")

sudo pkill -9 sccache || true
if test "${#old_containers[*]}" -gt 0; then
    docker rm -f "${old_containers[@]}" 2>/dev/null || true;
fi

sudo rm -rf /tmp/sccache_*.txt /tmp/sccache /tmp/sccache_system_test* /tmp/sccache_dist/*/{dist,test}*

if test $# -eq 0; then
    set -- test_dist_
elif test "$1" = --; then
    set -- test_dist_ "$@"
fi

if ! test -n "${RUST_BACKTRACE:+x}"; then
    RUST_BACKTRACE="1"
fi

RUST_BACKTRACE="${RUST_BACKTRACE:-}" \
CC="$(which gcc || which clang || which nvc)" \
CXX="$(which g++ || which clang++ || which nvc++)" \
CUDAHOSTCXX="$(which g++ || which clang++ || which nvc++)" \
cargo test --profile dev -F all,vendored-openssl,dist-client,dist-server,dist-tests "$@"
